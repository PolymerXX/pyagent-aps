# 复制本文件为 `.env` 并填写；不要将含真实密钥的 `.env` 提交到 Git。
# `core/config.py` 会在导入时对 `aps/.env` 执行 load_dotenv，供 Logfire 等读环境变量；
# APS_ 前缀配置仍由 pydantic-settings 从同一文件读取。

# --- Logfire（写入云端控制台需要 Write Token）---
# 在与你浏览器一致的区域内创建项目并生成 token（美区 / 欧区 token 不通用）：
# https://docs.pydantic.dev/logfire/reference/data-regions/
# LOGFIRE_TOKEN=

# 可选：SDK 默认 endpoint 与项目区域不一致时，见官方说明设置：
# https://docs.pydantic.dev/logfire/reference/configuration/
# LOGFIRE_BASE_URL=

# 设为 false 时跳过 Logfire 初始化，且 UI 的 log_ui_event 不会上报
# APS_LOGFIRE_ENABLED=true
